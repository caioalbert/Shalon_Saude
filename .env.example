# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Vercel Blob Configuration
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Resend Configuration (Optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Asaas Configuration
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
# Fallback quando as configurações ainda não estiverem no admin/banco:
ASAAS_ADESAO_VALUE=49.90
ASAAS_MENSALIDADE_INDIVIDUAL_VALUE=49.90
ASAAS_MENSALIDADE_FAMILIAR_VALUE=79.90
ASAAS_DEFAULT_PLAN_TYPE=INDIVIDUAL
# Compatibilidade legada (opcional):
ASAAS_MENSALIDADE_VALUE=49.90
ASAAS_MENSALIDADE_BILLING_TYPE=PIX
ASAAS_MENSALIDADE_BILLING_TYPES=PIX,BOLETO,CREDIT_CARD

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=your-jwt-secret-key-change-in-production

# Admin credentials (optional bootstrap)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
